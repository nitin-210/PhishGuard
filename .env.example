# Copy this file to ".env" and paste your free API keys.
# The backend reads these to check link reputation. Without them it still
# runs and uses the AI model only (link checks are skipped, not failed).

# Get one at: https://www.virustotal.com  (sign up -> profile -> API key)
VIRUSTOTAL_API_KEY=

# Get one at: https://urlscan.io  (sign up -> settings -> API key)
URLSCAN_API_KEY=

# OPTIONAL: if you run the self-hosted detonation sandbox (see sandbox/),
# point the backend at it. When set, it is used instead of urlscan.io.
SANDBOX_URL=

